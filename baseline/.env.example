# Baseline .env (used by docker-compose)
# Copy to .env and set your values

ENVIRONMENT=development
LOG_LEVEL=INFO
GROQ_API_KEY=your-groq-api-key-here
DEFAULT_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=1024
TEMPERATURE=0.7
USE_MOCK=false
QUEUE_TYPE=memory
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:80
