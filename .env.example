# =============================================================================
# Production AI System - Environment Configuration
# Dev server: avoid running on public networks (esbuild vulnerability)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Groq API ---
GROQ_API_KEY=your-groq-api-key-here
DEFAULT_MODEL=llama-3.3-70b-versatile
MAX_TOKENS=1024
TEMPERATURE=0.7

# --- Service URLs (for local development without Docker) ---
MODEL_SERVICE_URL=http://localhost:8001
WORKER_SERVICE_URL=http://localhost:8002

# --- Service URLs (for Docker) ---
# MODEL_SERVICE_URL=http://model-service:8001
# WORKER_SERVICE_URL=http://worker-service:8002

# --- Queue ---
QUEUE_TYPE=memory
REDIS_URL=redis://localhost:6379/0

# --- API Gateway ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Mock mode (set to true for offline/testing) ---
USE_MOCK=false
